//1пёЏвѓЈ Create a class **Book * *with the following properties:

//вЂў `BookId` (int) вЂ“ Unique identifier
//вЂў `Title` (string) вЂ“ Book title
//вЂў `Author` (string) вЂ“ Author name
//вЂў `Category` (string) вЂ“ Book category
//вЂў `IsAvailable` (bool) вЂ“ Availability status
using System;
using System.Collections.Generic;
using System.Linq;
using System.Reflection.Metadata;

class Book
{
    public int BookId { get; set; }
    public string Title { get; set; }
    public string Author { get; set; }
    public string Category { get; set; }
    public bool IsAvailable { get; set; } = true;

    public Book(int bookId, string title, string author, string category)
    {
        BookId = bookId;
        Title = title;
        Author = author;
        Category = category;
    }
}

//=================================

//2пёЏвѓЈ Create an interface **ILibraryService * *with the following methods:

//AddBook(Book book)
//RemoveBook(int bookId)
//IssueBook(int bookId)
//ReturnBook(int bookId)
//DisplayBooks()

interface ILibraryService
{
    void AddBook(Book book);
    void RemoveBook(int bookId);
    void IssueBook(int bookId);
    void ReturnBook(int bookId);
    void DisplayBooks();
}

//================================
//*Section 3: Business Logic*

//3пёЏвѓЈ Implement **AddBook()** using attributes

//Requirements:
//вЂў BookId must be unique
//вЂў New books should be **available by default** 


//4пёЏвѓЈ Implement **RemoveBook()** using attributes

//Conditions:
//вЂў Book should exist
//вЂў Issued books **cannot be removed**

//5пёЏвѓЈ Implement **IssueBook()** 

//Rules:
//вЂў Book must exist
//вЂў Book must be **available**
//вЂў If already issued, show message:
//"Book already issued"

//6пёЏвѓЈ Implement** ReturnBook()**

//Rules:
//вЂў Book must exist
//вЂў Book must currently be issued

//use dictionary to store books with bookId as key

class LibraryServiceImpl : ILibraryService
{
    private static LibraryServiceImpl _instance;
    private Dictionary<int, Book> _books;
    private LibraryServiceImpl()
    {
        _books = new Dictionary<int, Book>();
    }
    public static LibraryServiceImpl Instance
    {
        get
        {
            if (_instance == null)
            {
                _instance = new LibraryServiceImpl();
            }
            return _instance;
        }
    }
    public void AddBook(Book book)
    {
        if (_books.ContainsKey(book.BookId))
        {
            Console.WriteLine("Book ID must be unique.");
            return;
        }
        _books.Add(book.BookId, book);
        Console.WriteLine($"Book '{book.Title}' added successfully.");
    }
    public void RemoveBook(int bookId)
    {
        if (!_books.ContainsKey(bookId))
        {
            Console.WriteLine("Book not found.");
            return;
        }
        if (!_books[bookId].IsAvailable)
        {
            Console.WriteLine("Issued books cannot be removed.");
            return;
        }
        _books.Remove(bookId);
        Console.WriteLine($"Book with ID {bookId} removed successfully.");
    }
    public void IssueBook(int bookId)
    {
        if (!_books.ContainsKey(bookId))
        {
            Console.WriteLine("Book not found.");
            return;
        }
        if (!_books[bookId].IsAvailable)
        {
            Console.WriteLine("Book already issued.");
            return;
        }
        _books[bookId].IsAvailable = false;
        Console.WriteLine($"Book with ID {bookId} issued successfully.");
    }
    public void ReturnBook(int bookId)
    {
        if (!_books.ContainsKey(bookId))
        {
            Console.WriteLine("Book not found.");
            return;
        }
        if (_books[bookId].IsAvailable)
        {
            Console.WriteLine("Book is not currently issued.");
            return;
        }
        _books[bookId].IsAvailable = true;
        Console.WriteLine($"Book with ID {bookId} returned successfully.");
    }
    public void DisplayBooks()
    {
        var sortedBooks = _books.Values.OrderBy(b => b.Title).ToList();
        foreach (var book in sortedBooks)
        {
            Console.WriteLine($"ID: {book.BookId}, Title: {book.Title}, Author: {book.Author}, Category: {book.Category}, Available: {book.IsAvailable}");
        }
    }
}