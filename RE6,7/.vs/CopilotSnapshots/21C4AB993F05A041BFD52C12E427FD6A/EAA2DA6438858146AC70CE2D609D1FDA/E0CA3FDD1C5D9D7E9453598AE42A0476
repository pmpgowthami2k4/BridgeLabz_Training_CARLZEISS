using System;
using System.Collections.Generic;
using System.Text;
using System.Reflection;

//reflection to BookCategoryAttribute

public class BookCategoryReflection
{
    public static void DisplayAttributeInfo()
    {
        Type attributeType = typeof(BookCategoryAttribute);

        Console.WriteLine("Attribute Name: " + attributeType.Name);
        Console.WriteLine("Base Type: " + attributeType.BaseType.Name);
        Console.WriteLine();

        // Get allowed categories using reflection
        var field = attributeType.GetField("AllowedCategories", BindingFlags.NonPublic | BindingFlags.Static);
        if (field != null)
        {
            string[] categories = (string[])field.GetValue(null);
            Console.WriteLine("Allowed Categories:");
            foreach (string category in categories)
            {
                Console.WriteLine("  - " + category);
            }
        }
    }
}





